{
  "name": "@agentix/contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy": "hardhat run scripts/deploy.ts",
    "deploy:localhost": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:baseSepolia": "hardhat run scripts/deploy.ts --network baseSepolia",
    "test:onchain": "hardhat run scripts/test-onchain.ts",
    "test:onchain:baseSepolia": "hardhat run scripts/test-onchain.ts --network baseSepolia",
    "verify": "hardhat run scripts/verify-all.ts",
    "verify:baseSepolia": "hardhat run scripts/verify-all.ts --network baseSepolia",
    "extract-abis": "node scripts/extract-abis.js"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.3.0",
    "@openzeppelin/contracts-upgradeable": "5.3.0",
    "run": "^1.5.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
