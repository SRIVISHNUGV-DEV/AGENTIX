# ─── Server ──────────────────────────────────────────────────────
# Port the backend runs on.
PORT=3001

# 'development' or 'production'
NODE_ENV=development

# ─── Blockchain (RPC & Network) ─────────────────────────────────
# [median users] Sign up at alchemy.com → create a Sepolia app → paste its HTTPS endpoint here.
# [Org user]   Your own Sepolia RPC (Alchemy, Infura, local node, etc.).
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-alchemy-api-key

# Sepolia = 11155111 | Ethereum mainnet = 1 | Polygon = 137
CHAIN_ID=11155111

# Must match CHAIN_ID – just a human-readable label.
NETWORK_NAME=sepolia

# ─── Wallet (Backend Signer) ────────────────────────────────────
# [median users] Export the private key (0x-prefixed hex) of your Sepolia wallet from
#                MetaMask (Account Details → Export Private Key) or a burner wallet.
# [Org user]     A dedicated backend signer wallet funded with Sepolia ETH.
#                NEVER commit this value. Use a vault or env injection in prod.
PRIVATE_KEY=your-backend-wallet-private-key

# ─── Smart Contract Addresses (Sepolia) ─────────────────────────
# These are the live addresses deployed on Sepolia. No changes needed unless you deploy
# your own instances – in that case replace with your fresh deploy addresses.

# Groth16 verifier – verifies ZK proofs on-chain.
VERIFIER_ADDRESS=0x9536B6350c39475AE6191f2c1A8CDFdbd8586B46
# Manages credential merkle root and revocation sparse-merkle tree.
CREDENTIAL_REGISTRY_ADDRESS=0x77caeF0dD1F00cf36D2870E7Fb43112adB8fB0dc
# Creates & validates both ZK-proof and lightweight sessions.
SESSION_MANAGER_ADDRESS=0x30442c4F4E7098c4698276BBc8D3F79C7Fc41259
# Deterministic ERC-4337 smart-account factory.
AGENT_WALLET_FACTORY_ADDRESS=0xFaDAe432B8821C4B0690fd80f923F43fd85b4824
# ERC-1967 proxy implementation for agent wallets.
AGENT_WALLET_IMPLEMENTATION_ADDRESS=0x03F7Fc29cEFAC155419761Ac61705B84b71f29fe
# ERC-4337 EntryPoint singleton.
ENTRY_POINT_ADDRESS=0x4337084D9E255Ff0702461CF8895CE9E3b5Ff108

# ─── Bundler (UserOperation relayer) ────────────────────────────
# [median users] Same as RPC_URL – Alchemy also acts as a bundler.
# [Org user]     Self-hosted bundler (e.g. eth-infinitism/bundler) or paid provider.
BUNDLER_URL=https://eth-sepolia.g.alchemy.com/v2/your-alchemy-api-key

# ─── Encryption Keys ────────────────────────────────────────────
# [All users] Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#             64 hex characters (AES-256-GCM). Store securely – lost keys = lost data.

# Used to encrypt DB-stored private data at rest.
ENCRYPTION_KEY=your-64-hex-char-encryption-key

# Used to encrypt session private keys for autonomous agent transactions.
SESSION_ENCRYPTION_KEY=your-64-hex-char-session-key

# ─── Database (PostgreSQL) ──────────────────────────────────────
# [median users] Local Postgres via Docker:  docker run -e POSTGRES_USER=agentix -e POSTGRES_PASSWORD=agentix-secret -e POSTGRES_DB=agentix -p 5432:5432 postgres:16
# [Org user]     AWS RDS, Cloud SQL, or any managed Postgres. Replace the full URL below.
DATABASE_URL=postgresql://agentix:agentix-secret@localhost:5432/agentix

# Connection pool size (default 20 is fine for most setups).
DB_POOL_SIZE=20
# Disable (= disable) for local dev, enable (= require) for cloud DBs.
DB_SSL_MODE=disable
# All timeouts in milliseconds – tune based on network latency.
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000
DB_STATEMENT_TIMEOUT_MS=60000
# Visible in pg_stat_activity – helps identify this app's connections.
DB_APPLICATION_NAME=agentix-backend

# ─── Redis (BullMQ Job Queue) ───────────────────────────────────
# [median users] Local Redis via Docker:  docker run -p 6379:6379 redis:7
# [Org user]     AWS ElastiCache, Redis Cloud, or self-hosted.
#                Format: redis://[[username:]password@]host[:port][/db]
REDIS_URL=redis://localhost:6379

# Set 'true' when Redis is available (enables async proof generation).
# Set 'false' to skip the queue (proofs generated synchronously).
ENABLE_PROOF_QUEUE=false

# ─── Event Sync ─────────────────────────────────────────────────
# When 'true' the backend polls the chain for on-chain events (sessions created, etc.)
ENABLE_EVENT_SYNC=true

# ─── CORS ──────────────────────────────────────────────────────
# [median users] http://localhost:3000 (Next.js dev server).
# [Org user]     Your production frontend domain, comma-separated if multiple.
#                e.g. https://app.agentix.example.com,https://admin.agentix.example.com
CORS_ORIGIN=http://localhost:3000

# ─── Monitoring & Security ──────────────────────────────────────
# [All users] Generate a random token:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used for metric endpoint authentication.
METRICS_API_KEY=your-long-random-token

# When 'false', agents must use the platform UI (safer for production).
# When 'true', agents can call their own endpoints directly (useful during development).
ALLOW_PRIVATE_AGENT_ENDPOINTS=true
