# ─── Agentix Environment Template ─────────────────────────────
# Copy this file to the appropriate .env file for each workspace.

# ─── Backend (backend/.env) ────────────────────────────────────
PORT=3001
NODE_ENV=development

# Blockchain
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-alchemy-key
CHAIN_ID=11155111
NETWORK_NAME=sepolia
PRIVATE_KEY=0xyour-private-key
BUNDLER_URL=https://eth-sepolia.g.alchemy.com/v2/your-alchemy-key

# Contract addresses (Sepolia)
VERIFIER_ADDRESS=0x9536B6350c39475AE6191f2c1A8CDFdbd8586B46
SESSION_MANAGER_ADDRESS=0x30442c4F4E7098c4698276BBc8D3F79C7Fc41259
CREDENTIAL_REGISTRY_ADDRESS=0x77caeF0dD1F00cf36D2870E7Fb43112adB8fB0dc
AGENT_WALLET_FACTORY_ADDRESS=0xFaDAe432B8821C4B0690fd80f923F43fd85b4824
AGENT_WALLET_IMPLEMENTATION_ADDRESS=0x03F7Fc29cEFAC155419761Ac61705B84b71f29fe
ENTRY_POINT_ADDRESS=0x4337084D9E255Ff0702461CF8895CE9E3b5Ff108
CAPABILITY_REGISTRY_ADDRESS=0x57eEc0D86b79c4107fE57f5A2092794EF073B9b2
DELEGATION_MANAGER_ADDRESS=0x6AF9cccd6BC58ea4379725311784F8ba67528989

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-64-char-hex-encryption-key
SESSION_ENCRYPTION_KEY=your-64-char-hex-session-key

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/agentix
DB_POOL_SIZE=20
DB_SSL_MODE=disable

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379
ENABLE_PROOF_QUEUE=false

# Event sync
ENABLE_EVENT_SYNC=true

# CORS
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Monitoring
METRICS_API_KEY=replace-with-long-random-token
ALLOW_PRIVATE_AGENT_ENDPOINTS=true

# ─── Frontend (frontend/.env.local) ────────────────────────────
NEXT_PUBLIC_AGENT_CREDENTIALS_API_URL=http://127.0.0.1:3001
AGENT_CREDENTIALS_API_URL=http://127.0.0.1:3001
NEXT_PUBLIC_CHAIN_ID=11155111

# ─── MCP Test Server (mcp-test/.env) ───────────────────────────
# See mcp-test/.env.example for contract addresses

# ─── Runtime Local (runtime-local/.env) ───────────────────────
# RPC_URL, PRIVATE_KEY, OPENAI_API_KEY
