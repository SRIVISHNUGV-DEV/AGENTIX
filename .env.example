# ─── Agentix Environment Template ─────────────────────────────
# Copy this file to the appropriate .env file for each workspace.

# ─── Backend (backend/.env) ────────────────────────────────────
PORT=3001
NODE_ENV=development

# Blockchain
RPC_URL=https://base-sepolia.g.alchemy.com/v2/your-alchemy-key
CHAIN_ID=84532
NETWORK_NAME=sepolia
PRIVATE_KEY=0xyour-private-key
BUNDLER_URL=https://base-sepolia.g.alchemy.com/v2/your-alchemy-key

# Contract addresses (Base Sepolia)
VERIFIER_ADDRESS=0x6cBbB06df8Ddc8D28992F5149C755aAe0E0EB61f
SESSION_MANAGER_ADDRESS=0xcC0a3400397F8A54e54DA2c7A703bC5B27354C58
CREDENTIAL_REGISTRY_ADDRESS=0x83e0e671c0D31a288B93B9F04B7c4e116a065F5c
AGENT_WALLET_FACTORY_ADDRESS=0x6313d16266FB2e60c8Ef142274e317878ba71677
AGENT_WALLET_IMPLEMENTATION_ADDRESS=0x31448C7ca90c675F7f0631AF8A6a8627758E1e9A
CAPABILITY_REGISTRY_ADDRESS=0xA5624939Fd99ed689Bc564FB2a09B3bc59198297
DELEGATION_MANAGER_ADDRESS=0xa52e7C76811FAAC1514712eb0137d8f1631202DA

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-64-char-hex-encryption-key
SESSION_ENCRYPTION_KEY=your-64-char-hex-session-key

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/agentix
DB_POOL_SIZE=20
DB_SSL_MODE=disable

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379
ENABLE_PROOF_QUEUE=false

# Event sync
ENABLE_EVENT_SYNC=true

# CORS
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Monitoring
METRICS_API_KEY=replace-with-long-random-token
ALLOW_PRIVATE_AGENT_ENDPOINTS=true

# ─── Frontend (frontend/.env.local) ────────────────────────────
NEXT_PUBLIC_AGENT_CREDENTIALS_API_URL=http://127.0.0.1:3001
AGENT_CREDENTIALS_API_URL=http://127.0.0.1:3001
NEXT_PUBLIC_CHAIN_ID=84532

# ─── MCP Test Server (mcp-test/.env) ───────────────────────────
# See mcp-test/.env.example for contract addresses

# ─── Runtime Local (runtime-local/.env) ───────────────────────
# RPC_URL, PRIVATE_KEY, OPENAI_API_KEY
