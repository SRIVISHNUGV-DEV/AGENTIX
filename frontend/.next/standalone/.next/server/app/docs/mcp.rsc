t agent permission bitmask\nPOST /mcp/call\n{\n  \"name\": \"get_permissions\",\n  \"arguments\": {\n    \"agentId\": 1,\n    \"orgId\": 1\n  }\n}\n\n# Response\n{\n  \"permissions\": 255,\n  \"capabilities\": [\n    \"read_file\", \"write_file\", \"execute_command\",\n    \"query\", \"api_call\", \"sign_transaction\",\n    \"deploy_contract\", \"custom\"\n  ]\n}"}]}]]}]]}]
