lassName":"p-4 overflow-x-auto","children":["$","code",null,{"className":"text-sm font-mono text-zinc-300 whitespace-pre","children":"# create_session - Create on-chain session with ZK proof\nPOST /mcp/call\n{\n  \"name\": \"create_session\",\n  \"arguments\": {\n    \"agentId\": 1,\n    \"orgId\": 1,\n    \"maxValue\": \"1000000000000000000\",  // Optional: Max tx value\n    \"expirySeconds\": 7200               // Optional: Duration (default 3600)\n  }\n}\n\n# Response\n{\n  \"session\": {\n    \"sessionId\": \"session_0x...\",\n    \"sessionKey\": \"0x...\",\n    \"expiresAt\": 1715624400\n  },\n  \"zkProof\": { ... }\n}"}]}]]}]]}]
