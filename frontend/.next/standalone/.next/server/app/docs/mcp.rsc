 - Add contract to agent's whitelist\nPOST /mcp/call\n{\n  \"name\": \"add_whitelist\",\n  \"arguments\": {\n    \"agentId\": 1,\n    \"orgId\": 1,\n    \"address\": \"0xContractAddress...\",\n    \"name\": \"USDC\",              // Optional: Contract name\n    \"abi\": \"[{...}]\"             // Optional: Contract ABI JSON\n  }\n}\n\n# list_whitelist - List whitelisted contracts\nPOST /mcp/call\n{\n  \"name\": \"list_whitelist\",\n  \"arguments\": {\n    \"agentId\": 1,\n    \"orgId\": 1\n  }\n}"}]}]]}]]}]
