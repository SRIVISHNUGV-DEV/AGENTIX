{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/agents/layout,_N_T_/agents/new/layout,_N_T_/agents/new/page,_N_T_/agents/new"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/agents/new/__PAGE__",
    "/agents/new",
    "/agents",
    "/_index",
    "/_head"
  ]
}