d:["$","div",null,{"className":"mt-6 rounded-lg bg-zinc-950 border border-zinc-800 overflow-hidden","children":[["$","div",null,{"className":"flex items-center justify-between px-4 py-2 border-b border-zinc-800 bg-zinc-900/50","children":["$","span",null,{"className":"text-xs text-zinc-500 font-mono","children":"typescript"}]}],["$","pre",null,{"className":"p-4 overflow-x-auto","children":["$","code",null,{"className":"text-sm font-mono text-zinc-300 whitespace-pre","children":"import { AgentClient, AGENT_PERMISSIONS } from \"@agentix/sdk\"\n\n// Step 1: Initialize the client\nconst client = new AgentClient(\"http://127.0.0.1:3001\")\nawait client.init()\n\n// Step 2: Register an agent with ZK credentials\nconst registration = await client.registerAgent({\n  orgName: \"Acme Treasury\",\n  agentName: \"Payout Agent\",\n  permissions: AGENT_PERMISSIONS.ALL,\n  expiry: Math.floor(Date.now() / 1000) + 60 * 60 * 24 * 30\n})\n\n// Step 3: Deploy an ERC-4337 wallet\nconst wallet = await client.createWallet({ agentId: registration.agentId })\n\n// Step 4: Create an on-chain session\nconst session = await client.createSession({ agentId: registration.agentId })\n\n// Step 5: Execute actions\nconst result = await client.readFile(registration.agentId, \"/data/config.json\")\nconsole.log(result.execution.result)"}]}]]}]
