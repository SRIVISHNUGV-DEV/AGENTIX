# Root production example for shared deployment tooling.

# Public/backend URLs
AGENT_CREDENTIALS_API_URL=https://api.agentix.example.com
NEXT_PUBLIC_AGENT_CREDENTIALS_API_URL=https://api.agentix.example.com
CORS_ORIGIN=https://app.agentix.example.com

# PostgreSQL (AWS RDS)
DATABASE_URL=postgresql://agentix_user:replace-with-password@agentix-prod.cqneccqkglt4.us-east-1.rds.amazonaws.com:5432/agentix
DB_SSL_MODE=require
DB_POOL_SIZE=20
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000
DB_STATEMENT_TIMEOUT_MS=60000

# Redis / queues
REDIS_URL=redis://redis:6379
ENABLE_PROOF_QUEUE=true

# App security
ENCRYPTION_KEY=replace-with-64-hex-characters
METRICS_API_KEY=replace-with-long-random-token
SENTRY_DSN=

# Blockchain
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/replace-with-alchemy-key
BUNDLER_URL=https://eth-sepolia.g.alchemy.com/v2/replace-with-alchemy-key
CHAIN_ID=11155111
NETWORK_NAME=sepolia
PRIVATE_KEY=replace-with-backend-wallet-private-key
VERIFIER_ADDRESS=0x18a2447623f8DD51f13a41025cddFa218d0B2379
SESSION_MANAGER_ADDRESS=0xCfc4543476069Ed15f5749B527BC35fEAcA1Ab65
CREDENTIAL_REGISTRY_ADDRESS=0x5578d8DC741bcfAA199BCD0eDE68dcB3eb5EdEd7
AGENT_WALLET_FACTORY_ADDRESS=0x2fA255257c301755288e85DedAAe99d54f367970
AGENT_WALLET_IMPLEMENTATION_ADDRESS=0x97D6893A5483005eCed724FfedAAeaaAf6Da0C7F
ENTRY_POINT_ADDRESS=0x4337084D9E255Ff0702461CF8895CE9E3b5Ff108
ENABLE_EVENT_SYNC=true
