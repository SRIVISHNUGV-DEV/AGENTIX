# =============================================================================
# AGENTIX Production Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control - add it to .gitignore
# =============================================================================

# =============================================================================
# Server Configuration
# =============================================================================
PORT=3000
NODE_ENV=production

# =============================================================================
# Database Configuration
# Use postgresql://username:password@hostname:port/database for PostgreSQL
# =============================================================================

# Production (AWS RDS Example)
# DATABASE_URL=postgresql://postgres:YOUR_RDS_PASSWORD@agentix-prod.cqneccqkglt4.us-east-1.rds.amazonaws.com:5432/agentix

# Local Development
DATABASE_URL=postgresql://USERNAME:PASSWORD@localhost:5432/agentix

# Connection pool size (default: 10 for dev, 20 for production)
DB_POOL_SIZE=20

# SSL mode: 'require' for production AWS RDS, 'prefer' for local development
DB_SSL_MODE=require

# =============================================================================
# Security Configuration
# =============================================================================
# JWT_SECRET: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_A_256_BIT_SECRET_HERE

# CORS_ORIGIN: Comma-separated list of allowed frontend origins
CORS_ORIGIN=https://yourdomain.com

# METRICS_API_KEY: Secret key for accessing /metrics endpoint
METRICS_API_KEY=GENERATE_A_RANDOM_STRING_HERE

# Encryption key for sensitive data (64 hex characters)
ENCRYPTION_KEY=replace-with-64-hex-characters

# =============================================================================
# Redis Configuration (REQUIRED for BullMQ proof queue in production)
# =============================================================================
# Redis is REQUIRED for the async proof generation queue to work
REDIS_URL=redis://localhost:6379

# Alternative: Redis with authentication
# REDIS_URL=redis://:password@localhost:6379/0

# =============================================================================
# Blockchain Configuration
# =============================================================================
ENABLE_EVENT_SYNC=true

# RPC endpoint (Alchemy, Infura, etc.)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# Secondary RPC for failover
RPC_URLS=

# Contract Addresses (Sepolia testnet)
VERIFIER_ADDRESS=0x18a2...2379
CREDENTIAL_REGISTRY_ADDRESS=0x5578...dEd7
SESSION_MANAGER_ADDRESS=0xCfc4...Ab65
AGENT_WALLET_FACTORY_ADDRESS=0x2fA2...7970
AGENT_WALLET_IMPLEMENTATION_ADDRESS=0x...
ENTRY_POINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789

# Private key for backend wallet (NEVER commit real key!)
PRIVATE_KEY=

# Bundler configuration (for ERC-4337)
BUNDLER_URL=
BUNDLER_URLS=
BUNDLER_MAX_FEE_PER_GAS_GWEI=100
BUNDLER_MAX_PRIORITY_FEE_PER_GAS_GWEI=5

# =============================================================================
# Monitoring (optional)
# =============================================================================
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# =============================================================================
# Alchemy Configuration
# =============================================================================
ALCHEMY_API_KEY=YOUR_ALCHEMY_KEY
ALCHEMY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=info
# LOG_FILE=./logs/app.log

# =============================================================================
# Frontend URL (used by backend for CORS and webhooks)
# =============================================================================
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
FRONTEND_PORT=3001

# =============================================================================
# Email Configuration (optional - for notifications)
# =============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=notifications@yourdomain.com
# SMTP_PASS=your_app_password
# FROM_EMAIL=noreply@yourdomain.com
