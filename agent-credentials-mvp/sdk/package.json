{
  "name": "@agentix/sdk",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "browser": "dist/browser/index.js",
  "module": "dist/esm/index.js",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js",
      "browser": "./dist/browser/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.json",
    "build:esm": "tsc -p tsconfig.json --module esnext --outDir dist/esm",
    "build:browser": "esbuild src/index.ts --bundle --platform=browser --format=iife --outfile=dist/browser/index.js",
    "example:create-session": "tsx examples/create-session.ts",
    "example:perform-action": "tsx examples/perform-action.ts"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "circomlibjs": "^0.1.7",
    "ethers": "^6.13.4",
    "snarkjs": "^0.7.5"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "esbuild": "^0.20.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "browser": {
    "crypto": false
  }
}
