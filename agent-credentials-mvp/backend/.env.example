NODE_ENV=production
PORT=3001

# Frontend origin(s), comma-separated in production.
CORS_ORIGIN=https://app.agentix.example.com

# PostgreSQL (AWS RDS or another managed service)
# Hostname below matches the current AWS RDS instance family already referenced in local config.
DATABASE_URL=postgresql://agentix_user:replace-with-password@agentix-prod.cqneccqkglt4.us-east-1.rds.amazonaws.com:5432/agentix
DB_SSL_MODE=require
DB_POOL_SIZE=20
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000
DB_STATEMENT_TIMEOUT_MS=60000
DB_APPLICATION_NAME=agentix-backend

# Monitoring and security
METRICS_API_KEY=replace-with-long-random-token
SENTRY_DSN=
ENCRYPTION_KEY=replace-with-64-hex-characters
ALLOW_PRIVATE_AGENT_ENDPOINTS=false

# Redis / queues
REDIS_URL=redis://redis:6379
ENABLE_PROOF_QUEUE=true

# Blockchain
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/replace-with-alchemy-key
CHAIN_ID=11155111
NETWORK_NAME=sepolia
PRIVATE_KEY=replace-with-backend-wallet-private-key
VERIFIER_ADDRESS=0x9536B6350c39475AE6191f2c1A8CDFdbd8586B46
SESSION_MANAGER_ADDRESS=0x30442c4F4E7098c4698276BBc8D3F79C7Fc41259
CREDENTIAL_REGISTRY_ADDRESS=0x77caeF0dD1F00cf36D2870E7Fb43112adB8fB0dc
AGENT_WALLET_FACTORY_ADDRESS=0xFaDAe432B8821C4B0690fd80f923F43fd85b4824
AGENT_WALLET_IMPLEMENTATION_ADDRESS=0x03F7Fc29cEFAC155419761Ac61705B84b71f29fe
ENTRY_POINT_ADDRESS=0x4337084D9E255Ff0702461CF8895CE9E3b5Ff108
BUNDLER_URL=https://eth-sepolia.g.alchemy.com/v2/replace-with-alchemy-key
ENABLE_EVENT_SYNC=true
