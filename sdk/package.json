{
  "name": "@agentix/sdk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "bun run build:cjs && bun run build:esm",
    "build:cjs": "tsc -p tsconfig.json",
    "build:esm": "tsc -p tsconfig.json --module esnext --outDir dist/esm",
    "build:browser": "esbuild src/index.ts --bundle --platform=browser --format=iife --outfile=dist/browser/index.js",
    "example:create-session": "bun run examples/create-session.ts",
    "example:perform-action": "bun run examples/perform-action.ts"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "circomlibjs": "^0.1.7",
    "ethers": "^6.13.4",
    "snarkjs": "^0.7.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.13.10",
    "esbuild": "^0.20.0",
    "typescript": "^5.8.2"
  }
}
